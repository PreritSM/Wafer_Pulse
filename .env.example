# Application
WAFER_PROJECT_APP_NAME=Wafer Project API
WAFER_PROJECT_ENV=dev
WAFER_PROJECT_API_KEY=change-me

# Runtime Artifacts
WAFER_PROJECT_MODEL_PATH=models/best_model.pkl
WAFER_PROJECT_SCALER_PATH=data/Artifacts/feature_scaler.pkl
WAFER_PROJECT_SELECTED_FEATURES_PATH=data/Train_data/selected_features_secom_data.csv

# Payload limits
WAFER_PROJECT_REQUEST_LIMIT_BYTES=1000000
WAFER_PROJECT_BATCH_LIMIT_BYTES=10000000

# AWS
WAFER_PROJECT_AWS_REGION=us-east-1
WAFER_PROJECT_S3_BATCH_BUCKET=wafer-project-pm29
WAFER_PROJECT_S3_DVC_URI=s3://wafer-project-pm29/dvc-registry/
WAFER_PROJECT_S3_MLFLOW_ARTIFACTS_URI=s3://wafer-project-pm29/mlflow-artifacts/

# Database (RDS PostgreSQL)
WAFER_PROJECT_DB_HOST=localhost
WAFER_PROJECT_DB_PORT=5432
WAFER_PROJECT_DB_NAME=wafer_project
WAFER_PROJECT_DB_USER=wafer_user
WAFER_PROJECT_DB_PASSWORD=change-me
WAFER_PROJECT_DB_SSLMODE=require

# MLflow
WAFER_PROJECT_MLFLOW_TRACKING_URI=http://localhost:5000
WAFER_PROJECT_MLFLOW_EXPERIMENT_NAME=wafer-project
WAFER_PROJECT_RUN_OWNER=owner@example.com
WAFER_PROJECT_DVC_VERSION_ID=dvc-placeholder-version
WAFER_PROJECT_PR_AUC_BASELINE=0.0
